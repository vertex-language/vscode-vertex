{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*[^/]*:\\s*(//.*)?$",
    "decreaseIndentPattern": "^\\s*end\\b"
  },
  "folding": {
    "markers": {
      "start": "^\\s*[^/]*:\\s*(//.*)?$",
      "end": "^\\s*end\\b"
    }
  },
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z0-9_]+)?"
}