{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vertex",
  "scopeName": "source.vtx",
  "fileTypes": ["vtx"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#function-definition" },
    { "include": "#builtin-namespaces" },
    { "include": "#keywords-control" },
    { "include": "#execution-sigils" },
    { "include": "#storage-modifiers" },
    { "include": "#keywords-declaration" },
    { "include": "#constants" },
    { "include": "#builtin-functions" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#type-names" },
    { "include": "#intrinsics" },
    { "include": "#enum-member" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.vtx", "match": "//.*" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vtx",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.vtx", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.raw.multiline.vtx",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "characters": {
      "patterns": [
        { "name": "constant.character.vtx", "match": "'(\\\\.|[^'\\\\])'" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.hexadecimal.vtx", "match": "\\b0[xX](?:[0-9a-fA-F_]+(?:\\.[0-9a-fA-F_]*)?|\\.[0-9a-fA-F_]+)[pP][-+]?[0-9_]+" },
        { "name": "constant.numeric.integer.hexadecimal.vtx", "match": "\\b0[xX][0-9a-fA-F_]+" },
        { "name": "constant.numeric.integer.binary.vtx", "match": "\\b0[bB][01_]+" },
        { "name": "constant.numeric.integer.octal.vtx", "match": "\\b0[oO][0-7_]+" },
        { "name": "constant.numeric.float.decimal.vtx", "match": "\\b[0-9][0-9_]*(?:\\.[0-9_]+(?:[eE][-+]?[0-9_]+)?|[eE][-+]?[0-9_]+)" },
        { "name": "constant.numeric.integer.decimal.vtx", "match": "\\b[0-9][0-9_]*" }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(func)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.vtx" },
            "2": { "name": "entity.name.function.vtx" }
          }
        },
        { "name": "keyword.declaration.function.vtx", "match": "\\bfunc\\b" },
        {
          "match": "(?<=\\))\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.vtx" }
          }
        }
      ]
    },
    "builtin-namespaces": {
      "patterns": [
        {
          "match": "\\b(memory|runtime|tpu)(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "support.class.builtin.vtx" },
            "2": { "name": "punctuation.accessor.vtx" },
            "3": { "name": "support.function.builtin.vtx" }
          }
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        { "name": "keyword.control.vtx", "match": "\\b(if|else|switch|case|default|for|in|while|break|continue|return|fallthrough|defer|select)\\b" }
      ]
    },
    "execution-sigils": {
      "patterns": [
        { "name": "keyword.other.execution.vtx", "match": "\\b(thread|async|gpu|tpu)\\b" }
      ]
    },
    "storage-modifiers": {
      "patterns": [
        { "name": "storage.type.vtx", "match": "\\b(let|var)\\b" },
        { "name": "storage.modifier.vtx", "match": "\\b(mut|shared|unique|weak|abstract)\\b" }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        { "name": "keyword.declaration.vtx", "match": "\\b(struct|class|enum|type|import|package|build|init|test)\\b" }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.vtx", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.null.vtx", "match": "\\bnil\\b" }
      ]
    },
    "builtin-functions": {
      "patterns": [
        { "name": "support.function.builtin.vtx", "match": "\\b(print|panic|drop|reinterpret|sizeof|alignof|new|Expected)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.builtin.vtx", "match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64|int|uint|float32|float64|bool|string|char|void|tensor|typed_ptr|chan|map|bf16|fp8e4m3|fp8e5m2|int4)\\b" }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.vtx" }
          }
        }
      ]
    },
    "type-names": {
      "patterns": [
        { "name": "entity.name.type.vtx", "match": "\\b[A-Z][A-Za-z0-9_]*\\b" }
      ]
    },
    "intrinsics": {
      "patterns": [
        {
          "match": "(\\.)(transfer|upgrade)\\b",
          "captures": {
            "1": { "name": "punctuation.accessor.vtx" },
            "2": { "name": "support.function.intrinsic.vtx" }
          }
        }
      ]
    },
    "enum-member": {
      "patterns": [
        {
          "match": "(?<![\\w)\\]])(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.accessor.vtx" },
            "2": { "name": "variable.other.enummember.vtx" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.vtx", "match": "===|!==|&&|\\|\\||<<|>>|<=|>=|==|!=|->|\\.\\.|&\\+|&-|&\\*|\\+=|-=|\\*=|/=|%=|[-+*/%&|\\^~!<>=]" }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.block.vtx", "match": "[{}]" },
        { "name": "punctuation.section.parens.vtx", "match": "[()]" },
        { "name": "punctuation.section.brackets.vtx", "match": "[\\[\\]]" },
        { "name": "punctuation.separator.comma.vtx", "match": "," },
        { "name": "punctuation.separator.colon.vtx", "match": ":" },
        { "name": "punctuation.accessor.vtx", "match": "\\." }
      ]
    }
  }
}